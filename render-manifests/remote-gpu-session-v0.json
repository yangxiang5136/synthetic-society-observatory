{
  "schema": "sso.remote-render-session.v0",
  "id": "observatory-remote-gpu-session-v0",
  "title": "Synthetic Society Observatory Remote GPU Session V0",
  "runtime": {
    "transport": "webrtc-pixel-streaming",
    "browser_role": "send_camera_controls_and_decode_video",
    "remote_renderer_role": "render_scene_on_gpu_and_stream_pixels",
    "local_webgl_required": false,
    "static_build_endpoint": null,
    "endpoint_config_method": "url_query_renderEndpoint"
  },
  "controls": {
    "targets": [
      "view-overview",
      "view-observer",
      "view-first",
      "agent-001",
      "agent-002",
      "agent-003",
      "agent-004",
      "agent-005",
      "agent-006",
      "agent-007",
      "agent-008"
    ],
    "camera": {
      "yaw_degrees": {
        "min": 0,
        "max": 360,
        "step": 1,
        "wrap": true
      },
      "pitch_degrees": {
        "min": -35,
        "max": 45,
        "step": 1
      },
      "zoom": {
        "min": 0.7,
        "max": 1.8,
        "step": 0.05
      }
    },
    "observatory_state": [
      "selected_agent_id",
      "selected_event_id",
      "timeline_time",
      "time_phase",
      "active_view"
    ]
  },
  "fallback": {
    "mode": "pre_rendered_360_orbit_media",
    "mp4": "assets/spatial-orbit-v0.mp4",
    "poster": "assets/spatial-orbit-v0-poster.jpg",
    "yaw_mapping": "yaw_degrees maps linearly to media currentTime",
    "purpose": "cheap public preview when no remote GPU endpoint is connected"
  },
  "boundaries": {
    "private_modules_bundled": false,
    "visitor_gpu_role": "video_decode_only_by_default",
    "simulation_claim": "none",
    "engine_lock_in": "none"
  }
}
